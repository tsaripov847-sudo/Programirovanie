color1 = input('Введите первый цвет(красный, синий, зеленый): ')
color2 = input('Введите второй цвет(красный, синий, зеленый): ')
if color1 == color2:
    print('Цвета одинаковые')
elif color1 ==  'красный' and color2 == 'синий' or color1 =='синий' and color2 == 'красный':
    print('получился фиолетовый')
elif color1 ==  'красный' and color2 == 'желтый' or color1 =='желтый' and color2 == 'красный':
    print('получился оранжевый')
elif color1 ==  'синий' and color2 == 'желтый' or color1 =='желтый' and color2 == 'синий':
    print('получился зеленый')
else:
    print('Ошибка ввода')




